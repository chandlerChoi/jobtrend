# Neon connection string. Unset = falls back to the file-persisted mock DB
# (api/lib/mockBackend.ts) and the app still works with seeded sample data.
# Get one free at https://neon.tech -> New Project -> Connection string (pooled).
DATABASE_URL=

# 고용24(워크넷) Open API key. Unset = cron/collect-postings only re-aggregates
# whatever's already in job_postings instead of fetching real listings.
# Apply at https://www.work24.go.kr (공공데이터 Open API) — usually approved
# within a day, no business registration required for read-only job search.
WORK24_API_KEY=

# Anthropic API key for real F4 question generation/feedback. Unset = falls
# back to the deterministic mock in api/lib/claude.ts.
ANTHROPIC_API_KEY=

# Shared secret required in the x-vercel-cron-secret header on /api/cron/*.
# Unset = cron endpoints are open (fine for local dev only).
CRON_SECRET=

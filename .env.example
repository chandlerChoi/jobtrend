# Neon connection string. Unset = falls back to the file-persisted mock DB
# (api/lib/mockBackend.ts) and the app still works with seeded sample data.
# Get one free at https://neon.tech -> New Project -> Connection string (pooled).
DATABASE_URL=

# 고용24(워크넷) Open API key. Unset = cron/collect-news is a no-op.
# Individual accounts can only use 채용행사/공채속보/공채기업정보 — the
# 채용정보목록/상세 endpoints (per-posting requirements) return
# "개인회원은 사용할 수 없는 OPEN-API입니다." regardless of key. That's why
# F1/F2/F3 are built around the 3 services that *are* available — see
# api/lib/normalizers.ts.
WORK24_API_KEY=

# Anthropic API key for real F4 question generation/feedback. Unset = falls
# back to the deterministic mock in api/lib/claude.ts.
ANTHROPIC_API_KEY=

# Shared secret required in the x-vercel-cron-secret header on /api/cron/*.
# Unset = cron endpoints are open (fine for local dev only).
CRON_SECRET=

# Supabase project (Settings > API in the Supabase dashboard). Used for
# email/password auth on /login. VITE_ prefix required for Vite to expose
# these to client code — never put the service_role/secret key here.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
